#!/usr/bin/env bash
# ZhiQian YunShu validation script (config)
# Task ID :  task_id 
# Target  :  target_db 
# Object  :  suggestion.target 
# Index   :  index 

set -euo pipefail

CFG_FILE=" suggestion.file | default(suggestion.target.split('#')[0]) "

echo "[INFO] checking config file: $CFG_FILE"

if [[ ! -f "$CFG_FILE" ]]; then
  echo "[FAIL] config file not found: $CFG_FILE"
  exit 1
fi

if grep -E "jdbc:opengauss://" "$CFG_FILE" > /dev/null; then
  echo "[PASS] JDBC URL has been switched to openGauss"
else
  echo "[WARN] no jdbc:opengauss:// prefix detected, please review manually"
fi

if grep -E "jdbc:mysql://" "$CFG_FILE" > /dev/null; then
  echo "[FAIL] jdbc:mysql:// is still present and must be removed"
  exit 2
fi

echo "[OK] config item  suggestion.target  validated"
