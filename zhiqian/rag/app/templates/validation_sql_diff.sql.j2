-- 智迁云枢 验证脚本（方言及 SQL 重写类）
-- Task ID  :  task_id 
-- Target   :  target_db 
-- Object   :  suggestion.target 
-- Risk     :  suggestion.risk_level | default('UNKNOWN') 
-- Conf     :  suggestion.confidence | default('-') 
-- Index    :  index 

-- 1) 数量一致性：源库与目标库 row count 应相等
SELECT 'src' AS side, COUNT(*) AS row_count FROM source_schema. suggestion.target.split('.')[-1] | default('table_to_check') ;
SELECT 'dst' AS side, COUNT(*) AS row_count FROM target_schema. suggestion.target.split('.')[-1] | default('table_to_check') ;

-- 2) 样本数据 diff：限 100 行
SELECT *
FROM (
  SELECT * FROM target_schema. suggestion.target.split('.')[-1] | default('table_to_check') 
  EXCEPT
  SELECT * FROM source_schema. suggestion.target.split('.')[-1] | default('table_to_check') 
) diff
LIMIT 100;

-- 3) 检查原如改造后 SQL 语义是否运行成功
{% if suggestion.unified_diff %}
-- diff 参考：
{% for line in suggestion.unified_diff.split('\n') %}
--    line 
{% endfor %}
{% endif %}
