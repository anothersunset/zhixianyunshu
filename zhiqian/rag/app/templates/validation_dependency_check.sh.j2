#!/usr/bin/env bash
# ZhiQian YunShu validation script (dependency)
# Task ID :  task_id 
# Target  :  target_db 
# Object  :  suggestion.target 
# Index   :  index 

set -euo pipefail

POM_FILE=" suggestion.file | default('pom.xml') "

echo "[INFO] checking dependency declaration: $POM_FILE"

if grep -E "<artifactId>opengauss-jdbc</artifactId>" "$POM_FILE" > /dev/null; then
  echo "[PASS] opengauss-jdbc dependency present"
else
  echo "[FAIL] opengauss-jdbc dependency missing"
  exit 1
fi

if grep -E "<artifactId>mysql-connector-java</artifactId>" "$POM_FILE" > /dev/null; then
  echo "[FAIL] mysql-connector-java still present, must be removed"
  exit 2
fi

mvn -f "$POM_FILE" -q -DskipTests=true dependency:resolve
echo "[OK] dependency  suggestion.target  validated"
