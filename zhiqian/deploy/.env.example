# ===== Required =====
POSTGRES_PASSWORD=your-strong-password-here
JWT_SECRET=your-jwt-secret-at-least-32-bytes
ADMIN_PASSWORD=your-admin-password

# ===== Optional ports/database =====
POSTGRES_USER=zhiqian
POSTGRES_DB=zhiqian
JWT_TTL_MINUTES=60
WEB_HOST_PORT=80
BACKEND_HOST_PORT=8080
RAG_HOST_PORT=8001

# ===== v2-step-02: LLM =====
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_CHAT_MODEL=deepseek-v4-pro
LLM_REASONER_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=180
LLM_THINKING_ENABLED=true
LLM_REASONING_EFFORT=high

# ===== v2-step-04: BGE-M3 + Reranker =====
RAG_BUILD_ML=0
RAG_USE_BGE_M3=true
RAG_BGE_MODEL=BAAI/bge-m3
RAG_BGE_FP16=true
RAG_USE_RERANKER=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_FP16=true
RAG_EMBEDDING_DIM=1024
HF_ENDPOINT=https://hf-mirror.com

# ===== v2-step-05: Qdrant + RRF =====
RAG_USE_QDRANT=true
RAG_QDRANT_URL=http://qdrant:6333
RAG_QDRANT_API_KEY=
RAG_RRF_K=60

# ===== v2-step-06: Chunking =====
# chunk_strategy: semantic / late / none
RAG_CHUNK_STRATEGY=semantic
RAG_CHUNK_SIM_THRESHOLD=0.62
RAG_CHUNK_MAX_CHARS=1200
RAG_LATE_CHUNK_MAX_CHARS=600
RAG_LATE_CHUNK_OVERLAP=80

# ===== v2-step-07: Langfuse observability =====
# Leave blank to disable. Fill keys to report traces to Langfuse cloud or self-hosted Langfuse.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
