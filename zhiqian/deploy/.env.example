# ===== 必填配置 =====
# 数据库密码（至少 8 位）
POSTGRES_PASSWORD=your-strong-password-here
# JWT 密钥（至少 32 字节，可用 openssl rand -base64 32 生成）
JWT_SECRET=your-jwt-secret-at-least-32-bytes
# 管理员初始密码（仅首次启动生效）
ADMIN_PASSWORD=your-admin-password

# ===== 可选配置 =====
POSTGRES_USER=zhiqian
POSTGRES_DB=zhiqian
JWT_TTL_MINUTES=60
WEB_HOST_PORT=80
BACKEND_HOST_PORT=8080
RAG_HOST_PORT=8001

# ===== v2-step-02 新增：LLM 配置 =====
# 推荐 DeepSeek-V3.1：https://platform.deepseek.com 申请。
# 留空则后端自动启用 MockLlmClient，仍可启动且不报错。
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_CHAT_MODEL=deepseek-chat
LLM_REASONER_MODEL=deepseek-reasoner
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60

# 切换到 Qwen3 示例（只需修改下面三行，同代码零修改）：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_CHAT_MODEL=qwen3-32b-instruct
# LLM_REASONER_MODEL=qwen3-32b-reasoning
# 切换到 GLM-4.5 示例：
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_CHAT_MODEL=glm-4.5
# LLM_REASONER_MODEL=glm-4.5-reasoning
