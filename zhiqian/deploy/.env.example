# ===== 必填配置 =====
POSTGRES_PASSWORD=your-strong-password-here
JWT_SECRET=your-jwt-secret-at-least-32-bytes
ADMIN_PASSWORD=your-admin-password

# ===== 可选配置 =====
POSTGRES_USER=zhiqian
POSTGRES_DB=zhiqian
JWT_TTL_MINUTES=60
WEB_HOST_PORT=80
BACKEND_HOST_PORT=8080
RAG_HOST_PORT=8001

# ===== v2-step-02：LLM 配置 =====
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_CHAT_MODEL=deepseek-chat
LLM_REASONER_MODEL=deepseek-reasoner
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60

# ===== v2-step-04：BGE-M3 + Reranker 配置 =====
# RAG_BUILD_ML=0 默认走轻依赖 + hash 向量退化，构建快。
# RAG_BUILD_ML=1 时会装 torch + FlagEmbedding（镜像~2GB）。
# 首次启动会从 HuggingFace 拉~2GB 权重（走 HF_ENDPOINT 镜像源可加速）。
RAG_BUILD_ML=0
RAG_USE_BGE_M3=true
RAG_BGE_MODEL=BAAI/bge-m3
RAG_BGE_FP16=true
RAG_USE_RERANKER=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_FP16=true
RAG_EMBEDDING_DIM=1024
HF_ENDPOINT=https://hf-mirror.com
