{
  "_comment": "v2-step-21: Debezium MySQL source connector。POST 到 http://localhost:8083/connectors",
  "name": "zhiqian-mysql-source",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "cdc-mysql-source",
    "database.port": "3306",
    "database.user": "root",
    "database.password": "zhiqian",
    "database.server.id": "184054",
    "topic.prefix": "zhiqian.src",
    "database.include.list": "source_db",
    "table.include.list": "source_db.orders,source_db.customers,source_db.products",
    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "zhiqian.cdc.schema-changes",
    "include.schema.changes": "true",
    "snapshot.mode": "initial",
    "snapshot.locking.mode": "minimal",
    "decimal.handling.mode": "double",
    "time.precision.mode": "connect",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite"
  }
}
