{"id":"oracle-pg-004","pair":"oracle->postgresql","difficulty":"medium","category":"SQL_REWRITE","source_sql":"SELECT DECODE(g,1,'男',2,'女','未知') FROM person","gold_target_sql":"SELECT CASE g WHEN 1 THEN '男' WHEN 2 THEN '女' ELSE '未知' END FROM person","gold_report_points":["DECODE → CASE WHEN"],"gold_context_ids":["kb-func-decode"]}
